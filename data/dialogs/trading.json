{
  "head": {
    "class": "scripted",
    "conditional_tags": {},
    "style": "",
    "locutors": [
      "shopkeeper",
      "heroe"
    ],
    "name": "Trading",
    "about": "trading",
    "icon": null,
    "keywords": [],
    "events": {
      "Flag": {"value": false},
      "TriggerBuyScreen": {"participants": ["shopkeeper","heroe"]},
      "TriggerSellScreen": {"participants": ["shopkeeper","heroe"]},
      "Trade": {}
    },
    "panels": {
      "objects": {
        "default": 8
      },
      "themes": {
        "default": 8
      }
    },
    "trading": {
      "traders": ["shopkeeper"],
      "default": 9,
      "failure": 11
    }
  },
  "body": {
    "0": {
      "leads": [1,2,3],"from": "shopkeeper","to": "heroe","event": "Flag",
      "txt": "Buenos días. ¿Qué quiere hacer?"
    },
    "1": {
      "leads": 4,"from": "heroe","to": "shopkeeper","event": "TriggerBuyScreen",
      "txt": "Comprar"
    },
    "2": {
      "leads": 5,"from": "heroe","to": "shopkeeper","event": "TriggerSellScreen",
      "txt": "Vender"
    },
    "3": {
      "from": "heroe","to": "shopkeeper","event": "Trade","e_data": {"value": false},
      "#": "El evento Trade se dispara igual que 'No' para evitar un bucle continuo.",
      "txt": "Nada"
    },
    "4": {
      "leads": [6,7],"from": "shopkeeper","to": "heroe",
      "txt": "Esto te costará {coin}{price}. ¿Quieres comprar?"
    },
    "5": {
      "leads": [6,7],"from": "shopkeeper","to": "heroe",
      "txt": "Puedo pagarte {coin}{price} por esto. ¿estás seguro?"
    },
    "6": {
      "from": "heroe", "exclusive": [12, 13, 14],"to": "shopkeeper","event": "Trade","e_data": {"value": true},
      "txt": "Sí"
    },
    "7": {
      "from": "heroe","to": "shopkeeper","event": "Trade","e_data": {"value": false},
      "txt": "No"
    },
    "8": {
      "from": "shopkeeper","to": "heroe",
      "txt": "No sé que es eso."
    },
    "9": {
      "leads": 10,"from": "shopkeeper","to": "heroe",
      "txt": "No puedo comprarte eso."
    },
    "10": {
      "leads": [1,2,3],"from": "shopkeeper","to": "heroe",
      "txt": "¿Qué se le ofrece?"
    },
    "11": {
      "from": "shopkeeper", "to": "heroe",
      "txt": "No tienes nada que venderme."
    },
    "12": {"from": "shopkeeper", "to": "heroe", "leads": 15, "reqs": [{"loc": "heroe","left": "wallet","comparison": "<"},{"op": "buy"}],
      "txt": "No te alcanza el dinero."
    },
    "13": {"from": "shopkeeper", "to": "heroe", "leads": 15, "reqs": [{"loc": "shopkeeper","left": "wallet","comparison": "<"},{"op": "sell"}],
      "txt": "No me alcanza el dinero."
    },
    "14": {"from": "shopkeeper", "to": "heroe",
      "#": "es importante que el diálogo tenga donde caer al finalizar el intercambio",
      "txt": "Muchas gracias."
    },
    "15": {"from": "shopkeeper", "to": "heroe",
      "#": "Sea negativo o afirmativo.",
      "txt": "Lo siento mucho."}

  }
}
